# ---------------------------------------------------------------------------
# SkillBuilder environment. Copy to `.env.local` and fill in.
# The app boots without these: missing secrets degrade to stub adapters
# (see src/server/container.ts) so the architecture shell runs offline.
# ---------------------------------------------------------------------------

# Postgres (Neon/Supabase). Without it, persistence uses the in-memory adapter.
DATABASE_URL="postgresql://user:password@localhost:5432/skillbuilder?schema=public"

# Clerk auth (Google + GitHub). Without it, auth uses the stub adapter.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Model provider. Without a configured key for the selected provider, the build
# loop returns a clear "model provider not configured" error.
SKILLBUILDER_MODEL_PROVIDER="anthropic"

# Anthropic key, consumed through the Vercel AI SDK (@ai-sdk/anthropic).
# The server owns this key — it never reaches the client.
ANTHROPIC_API_KEY=""

# Nous Portal is OpenAI-compatible and uses bearer-token auth.
NOUS_API_KEY=""
NOUS_BASE_URL="https://inference-api.nousresearch.com/v1"

# Default model for the build loop. Use "Hermes-4.3-36B" with Nous.
SKILLBUILDER_MODEL="claude-opus-4-8"
