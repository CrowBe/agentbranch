# ---------------------------------------------------------------------------
# SkillSmith environment. Copy to `.env.local` and fill in.
# The app boots without these: missing secrets degrade to stub adapters
# (see src/server/container.ts) so the architecture shell runs offline.
# ---------------------------------------------------------------------------

# Postgres (Neon/Supabase). Without it, persistence uses the in-memory adapter.
DATABASE_URL="postgresql://user:password@localhost:5432/skillbuilder?schema=public"

# Clerk auth (Google + GitHub). Without it, auth uses the stub adapter.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Model provider + model selection below seed the **model router** registry: env
# sets the boot-time defaults, and the in-app **model console** (rail → Models)
# switches the active provider/model at runtime — or connects a bring-your-own
# key — without a redeploy. Every provider with a server key here is available to
# switch to. Server keys are owned by the server and never reach the client.

# Default active provider ("anthropic" | "nous"). Without a key for it, model
# calls fail with a clear "model provider not configured" error until one is set
# (here or in the console).
SKILLBUILDER_MODEL_PROVIDER="anthropic"

# Anthropic key, consumed through the Vercel AI SDK (@ai-sdk/anthropic).
ANTHROPIC_API_KEY=""

# Nous Portal is OpenAI-compatible and uses bearer-token auth.
NOUS_API_KEY=""
NOUS_BASE_URL="https://inference-api.nousresearch.com/v1"

# Default model for the active provider. Use "Hermes-4.3-36B" with Nous.
SKILLBUILDER_MODEL="claude-opus-4-8"

# Optional per-primitive model routes for the active provider (Opus for the
# streaming build loop, cheaper models for classify/generate). Defaults are
# sensible per provider; the console can override these live too.
# SKILLBUILDER_CLASSIFY_MODEL="claude-haiku-4-5"
# SKILLBUILDER_GENERATE_MODEL="claude-sonnet-4-6"
# SKILLBUILDER_RUN_AGENT_MODEL="claude-opus-4-8"
# SKILLBUILDER_STREAM_AGENT_MODEL="claude-opus-4-8"
