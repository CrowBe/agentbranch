// agent.branch data model — mirrors docs/ARCHITECTURE.md §6.
// The schema is *export-agnostic*: export shapes are rendered from the skill
// record, never stored. Persistence adapters live in src/infra/prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Identity, sourced from Clerk (Google / GitHub OAuth).
model User {
  id        String   @id // Clerk user id
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  skills     Skill[]
  usage      Usage?
  rateLimits RateLimitWindow[]
  testRuns   TestRun[]
  evalRuns   EvalRun[]

  @@map("users")
}

/// Append-only identity for the validation harness itself. The source artifacts
/// stay in git; this row records their hash identity so evaluation records are
/// attributable to the harness version that produced them (ARCHITECTURE §6).
model HarnessVersion {
  id                             String   @id @default(cuid())
  manifestHash                   String   @unique @map("manifest_hash")
  buildLoopSystemPromptHash      String   @map("build_loop_system_prompt_hash")
  lintRulesetHash                String   @map("lint_ruleset_hash")
  promptBatteryGeneratorHash     String   @map("prompt_battery_generator_hash")
  testRunWorldGeneratorHash      String   @map("test_run_world_generator_hash")
  distractorLibraryHash          String   @map("distractor_library_hash")
  gitSha                         String?  @map("git_sha")
  createdAt                      DateTime @default(now()) @map("created_at")

  testRuns TestRun[]
  evalRuns EvalRun[]

  @@map("harness_versions")
}

/// The persisted skill. Exports are rendered from this record.
///
/// `mainVersionId` is the **explicit blessed pointer** (ARCHITECTURE §6, §9.3):
/// the version everything defaults to (export, install, the hero's first paint).
/// In the linear-history path it tracks the newest revision; branching makes the
/// blessed version explicit and independent of newest, so a draft can append
/// higher revisions without becoming main. *Main is just the branch that owns
/// this version* — promote re-points it.
model Skill {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  name            String
  description     String
  body            String   @db.Text // the markdown body of SKILL.md
  frontmatterJson Json     @map("frontmatter_json")
  mainVersionId   String?  @unique @map("main_version_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  mainVersion SkillVersion? @relation("SkillMainVersion", fields: [mainVersionId], references: [id], onDelete: SetNull)
  versions    SkillVersion[]
  branches    SkillBranch[]
  testRuns    TestRun[]
  evalRuns    EvalRun[]

  @@index([userId])
  @@map("skills")
}

/// A line of iteration — a **draft** in user copy (ARCHITECTURE §9.3). *Main is
/// just a branch*: every version belongs to one, and the branch that owns the
/// skill's `mainVersionId` is the blessed lineage. A skill may carry several
/// open drafts at once; `status` flips to `discarded` when a draft is dropped or
/// the daily retention job tidies an over-cap draft. `ordinal` is the per-skill
/// display order ("Draft 1, 2…").
model SkillBranch {
  id        String   @id @default(cuid())
  skillId   String   @map("skill_id")
  status    String   @default("open") // open | discarded
  ordinal   Int // per-skill display order
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  skill    Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)
  versions SkillVersion[]

  @@index([skillId])
  @@map("skill_branches")
}

/// Append-only revisions of a skill. An export is a pure function of a version;
/// this also enables future regression evals. Versions chain as a **DAG** via
/// `parentId` and belong to a branch; `revision` is a **per-branch display
/// ordinal** (ARCHITECTURE §6) — two drafts advancing independently never
/// collide, so the old per-skill monotonic uniqueness is now per-branch.
model SkillVersion {
  id              String   @id @default(cuid())
  skillId         String   @map("skill_id")
  branchId        String   @map("branch_id")
  parentId        String?  @map("parent_id")
  revision        Int // per-branch display ordinal
  name            String
  description     String
  body            String   @db.Text
  frontmatterJson Json     @map("frontmatter_json")
  lintSummaryJson Json?    @map("lint_summary_json")
  createdAt       DateTime @default(now()) @map("created_at")

  skill       Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)
  branch      SkillBranch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  parent      SkillVersion?  @relation("SkillVersionParent", fields: [parentId], references: [id], onDelete: SetNull)
  children    SkillVersion[] @relation("SkillVersionParent")
  mainOfSkill Skill?         @relation("SkillMainVersion")
  testRuns    TestRun[]
  evalRuns    EvalRun[]

  @@unique([branchId, revision])
  @@index([skillId])
  @@index([branchId])
  @@map("skill_versions")
}

/// Per-user token + turn counters. Drives caps now; PAYG metering later.
model Usage {
  userId                       String   @id @map("user_id")
  tokensUsed                   Int      @default(0) @map("tokens_used")
  turnsUsed                    Int      @default(0) @map("turns_used")
  inputTokensUsed              Int      @default(0) @map("input_tokens_used")
  outputTokensUsed             Int      @default(0) @map("output_tokens_used")
  cacheReadInputTokensUsed     Int      @default(0) @map("cache_read_input_tokens_used")
  cacheCreationInputTokensUsed Int      @default(0) @map("cache_creation_input_tokens_used")
  periodStart                  DateTime @default(now()) @map("period_start")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("usage")
}

/// Fixed-window request-rate limiter, scoped per user and capability.
model RateLimitWindow {
  userId       String   @map("user_id")
  capability   String
  windowStart  DateTime @map("window_start")
  requestCount Int      @default(0) @map("request_count")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, capability])
  @@map("rate_limit_windows")
}

/// Recorded triggering-eval results: did the skill fire on the right prompts?
model EvalRun {
  id             String   @id @default(cuid())
  skillId        String   @map("skill_id")
  skillVersionId String?  @map("skill_version_id")
  harnessVersionId String? @map("harness_version_id")
  userId         String   @map("user_id")
  status         String // queued | running | passed | failed
  resultJson     Json     @map("result_json")
  createdAt      DateTime @default(now()) @map("created_at")

  skill        Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillVersion SkillVersion? @relation(fields: [skillVersionId], references: [id], onDelete: SetNull)
  harnessVersion HarnessVersion? @relation(fields: [harnessVersionId], references: [id], onDelete: SetNull)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([skillId])
  @@index([skillVersionId])
  @@index([harnessVersionId])
  @@map("eval_runs")
}

/// Recorded test-run results: skill executed against the mock-tool registry.
model TestRun {
  id             String   @id @default(cuid())
  skillId        String   @map("skill_id")
  skillVersionId String?  @map("skill_version_id")
  harnessVersionId String? @map("harness_version_id")
  userId         String   @map("user_id")
  status         String // queued | running | completed | failed
  scenarioJson   Json     @map("scenario_json")
  transcriptJson Json     @map("transcript_json")
  createdAt      DateTime @default(now()) @map("created_at")

  skill        Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillVersion SkillVersion? @relation(fields: [skillVersionId], references: [id], onDelete: SetNull)
  harnessVersion HarnessVersion? @relation(fields: [harnessVersionId], references: [id], onDelete: SetNull)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([skillId])
  @@index([skillVersionId])
  @@index([harnessVersionId])
  @@map("test_runs")
}
